# Supabase (required)
# Local: `pnpm supabase start` prints these
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Timezone for "today" calculations (IANA name)
APP_TIMEZONE=America/Chicago
# Optional: force the app's "today" to a fixed VBS date (YYYY-MM-DD). Overrides
# the system clock everywhere. Use to prep/run a day early; REMOVE once the real
# date catches up, or the app stays stuck on this day.
# APP_TODAY_OVERRIDE=2026-07-01

# Twilio (required for SMS — optional in dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# Resend (required for email — optional in dev)
RESEND_API_KEY=
RESEND_FROM=
RESEND_WEBHOOK_SECRET=

# Mapbox (required for geocoding + ETAs — optional in dev)
MAPBOX_TOKEN=

# Coordinator contact (shown on parent status page)
COORDINATOR_NAME=
COORDINATOR_PHONE=

# Sentry (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Cron protection (required in production; cron route returns 503 when unset)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# No-login (kiosk) mode. Set to "true" so staff don't sign in on shared devices
# — unauthenticated requests then act as the coordinator/admin on file. OFF by
# default: leaving this unset requires real sign-in, so the app can never grant
# coordinator power by accident. If you turn it on, ALSO restrict who can reach
# the deploy (Vercel Deployment Protection / trusted network) — the in-app role
# check no longer gates anything once this is on.
ALLOW_NO_LOGIN=

# Google Drive folder for staff-uploaded VBS photos/videos (optional).
# Share the folder "Anyone with the link → Editor" so volunteers can
# upload without a Google account. Paste the folder ID (the bit after
# /folders/ in the share URL).
NEXT_PUBLIC_DRIVE_FOLDER_ID=
